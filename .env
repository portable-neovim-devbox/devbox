# Neovim version to install: select from
# - "stable" (default)
# - specific version tag, e.g., "v0.9.8"
NEOVIM_VERSION=""

# Main user name inside the container
# Default: "user"
USER_NAME=""

# Locale setting for the container
# Default: "en_US.UTF-8"
LANG=""

# Proxy settings (leave empty if not needed)
HTTP_PROXY=""
HTTPS_PROXY=""
NO_PROXY=""
